<?xml version="1.0" encoding="UTF-8"?>
<addons>
    <addon id="repository.kadrplusde" name="KadrPlus DE Repository" version="1.0.0" provider-name="Kadr+">
        <extension point="xbmc.addon.repository" name="KadrPlus DE Repository">
            <dir>
                <info compressed="false">https://kadrplus.github.io/KadrPlusDE-repo/addons.xml</info>
                <checksum>https://kadrplus.github.io/KadrPlusDE-repo/addons.xml.md5</checksum>
                <datadir zip="true">https://kadrplus.github.io/KadrPlusDE-repo/zips/</datadir>
            </dir>
        </extension>
        <extension point="xbmc.python.module" library="." />
        <extension point="xbmc.addon.metadata">
            <summary lang="de">KadrPlus DE – deutschsprachige Quellen</summary>
            <summary lang="pl">KadrPlus DE – źródła w języku niemieckim</summary>
            <summary lang="en">KadrPlus DE – German language sources</summary>
            <description lang="de">Inoffizielle Erweiterung für deutschsprachige Videoquellen.</description>
            <platform>all</platform>
        </extension>
    </addon>
    <addon id="repository.kadrplusde" name="KadrPlus DE Repository" version="1.0.1" provider-name="Kadr+">
        <extension point="xbmc.addon.repository" name="KadrPlus DE Repository">
            <dir>
                <info compressed="false">https://kadrplus.github.io/KadrPlusDE-repo/addons.xml</info>
                <checksum>https://kadrplus.github.io/KadrPlusDE-repo/addons.xml.md5</checksum>
                <datadir zip="true">https://kadrplus.github.io/KadrPlusDE-repo/zips/</datadir>
            </dir>
        </extension>
        <extension point="xbmc.addon.metadata">
            <summary lang="de">KadrPlus DE – deutschsprachige Quellen</summary>
            <summary lang="en">KadrPlus DE – German language sources</summary>
            <description lang="de">Offizielles Repository für Kadr+ (deutsche Version).</description>
            <description lang="en">Official repository for Kadr+ (German version).</description>
            <assets>
                <icon>icon.png</icon>
            </assets>
        </extension>
    </addon>
    <addon id="plugin.video.kadrplusde" name="Kadr+" version="2.43.0" provider-name="Kadr+">
        <requires>
            <import addon="xbmc.python" version="3.0.0" />
            <import addon="script.module.requests" />
            <import addon="script.module.beautifulsoup4" />
            <import addon="script.module.future" />
            <import addon="script.module.six" />
            <import addon="script.module.kodi-six" optional="true" />
            <import addon="script.module.pyxbmct" optional="true" />
            <import addon="script.module.resolveurl" optional="true" />
            <import addon="script.module.kover" version="0.0.6" optional="true" />
            <import addon="inputstream.adaptive" />
            <import addon="script.module.inputstreamhelper" />
        </requires>
        <extension point="xbmc.python.pluginsource" library="default.py">
            <provides>video</provides>
        </extension>
        <extension point="xbmc.service" library="service.py" start="startup" />
        <extension point="kodi.context.item">
            <menu id="kodi.core.main">
                <item library="epg.py">
                    <label lang="de">In Kadr+ suchen</label>
                    <visible>Window.IsVisible(tvguide)|Window.IsVisible(tvsearch)|Window.IsVisible(tvchannels)</visible>
                </item>
            </menu>
        </extension>
        <extension point="xbmc.addon.metadata">
            <reuselanguageinvoker>true</reuselanguageinvoker>
            <summary lang="de">Kadr+ — Filme und Serien</summary>
            <summary lang="en">Kadr+ — Movies and TV Shows</summary>
            <description lang="de">Plugin für Filme und Serien.

Kadr+ — Modifikation basierend auf FanFilm.
Zusätzliche DE-Scraper, deutsche Übersetzung und Fehlerbehebungen.
Deutsche Version mit DE-Scrapern: Filmpalast, MegaKino1, Vavoo.</description>
            <description lang="en">Plugin for movies and TV shows.

Kadr+ — modification based on FanFilm.
Additional DE scrapers, German translation and bug fixes.
German version with DE scrapers: Filmpalast, MegaKino1, Vavoo.</description>
            <platform>all</platform>
            <assets>
                <icon>icon.png</icon>
                <fanart>fanart.jpg</fanart>
                <screenshot>resources/screenshot/screenshot01.png</screenshot>
                <screenshot>resources/screenshot/screenshot02.png</screenshot>
                <screenshot>resources/screenshot/screenshot03.png</screenshot>
            </assets>
            <news>Changelog:

2.26 (2026-03-08)
        - Ko-fi support page redesigned (link first, info below)
        - Settings: Ko-fi tab polished

2.25 (2026-03-08)
        - Ko-fi support tab added to settings
        - Removed emoji from menu labels (Kodi compatibility)

2.22 (2026-03-08)
        - Obfuscated source code (string encoding, docstrings removed)

2.21 (2026-03-08)
        - Added Ko-fi donation button (main menu + settings)
        - Plugin author changed to Kadr+

2.20 (2026-03-08)
        - Authorization labels unified: TRAKT/TMDB both show "Autorisierung"
        - HTTP server status translated to German

2.19 (2026-03-08)
        - All user-visible "KadrPlus" labels renamed to "Kadr+"
        - TMDB/Trakt authorization dialogs translated to German

2.18 (2026-03-07)
        - DE version: all Polish scrapers removed
        - Full German UI translation (settings, menus, dialogs)
        - TMDB language set to German (de)
        - Plugin ID: plugin.video.kadrplusde
        - MegaKino: removed yg_token requirement (works without login)

2.7 (2026-03-07)
        - Added MegaKino1.watch scraper (DE, movies + series)

1.0 (2026-03-04)
        - DE scrapers: Filmpalast.to, Vavoo.to
        - Based on FanFilm (open source)
</news>
        </extension>
    </addon>
</addons>